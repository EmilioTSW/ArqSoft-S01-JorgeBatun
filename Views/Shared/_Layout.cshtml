<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Catálogo Gamer</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Catalogo.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-gamer mb-4">
            <div class="container-fluid">
                <a class="navbar-brand logo-gamer" asp-area="" asp-controller="Home" asp-action="Index">
                    🎮 Catálogo Gamer
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Abrir navegación">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 ms-3">
                        <li class="nav-item">
                            <a class="nav-link nav-gamer" asp-area="" asp-controller="Home" asp-action="Index">
                                Inicio
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-gamer" asp-area="" asp-controller="Catalogo" asp-action="Index">
                                Catálogo
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-gamer" asp-area="" asp-controller="Catalogo" asp-action="Agregar">
                                Agregar juego
                            </a>
                        </li>
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="container contenido-principal">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-gamer">
        <div class="container">
            &copy; 2026 - Catálogo Gamer | Proyecto ASP.NET Core
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/gamer.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>