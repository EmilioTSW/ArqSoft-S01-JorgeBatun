@model List<Catalogo.Models.Item>

@{
    ViewData["Title"] = "Mi Catálogo";
}

<section class="catalogo-header animar">
    <h1>Mi Catálogo Gamer</h1>
    <p>Selecciona un género o explora todos los videojuegos.</p>
</section>

<div class="filtros animar">
    <a asp-action="Index" class="btn-filtro">Todos</a>

    @foreach (var gen in ViewBag.Generos as List<string>)
    {
        <a asp-action="Index" asp-route-genero="@gen" class="btn-filtro">@gen</a>
    }
</div>

<div class="catalogo-grid">
    @foreach (var item in Model)
    {
        <div class="card-juego animar">
            <div class="card-top">
                <span class="tag">@item.Genero</span>
                <span class="year">@item.Ano</span>
            </div>

            <h2>@item.Titulo</h2>

            <p>
                <strong>Consola:</strong> @item.Consola
            </p>

            <a asp-action="Detalle" asp-route-id="@item.Id" class="btn-detalle">
                Ver detalles
            </a>
        </div>
    }
</div>

<div class="acciones">
    <a asp-action="Agregar" class="btn-neon">+ Agregar videojuego</a>
</div>